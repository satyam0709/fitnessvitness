generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model schema_meta {
  key   String  @id @db.VarChar(64)
  value String? @db.VarChar(64)

  @@map("_schema_meta")
}

model chat_direct_pairs {
  pair_key     String       @id @db.VarChar(64)
  thread_id    Int          @db.UnsignedInt
  created_at   DateTime     @default(now()) @db.DateTime(0)
  chat_threads chat_threads @relation(fields: [thread_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cdp_thread")

  @@index([thread_id], map: "fk_cdp_thread")
}

model chat_thread_members {
  thread_id            Int                             @db.UnsignedInt
  user_id              Int                             @db.UnsignedInt
  member_role          chat_thread_members_member_role @default(member)
  joined_at            DateTime                        @default(now()) @db.DateTime(0)
  last_read_message_id Int?                            @db.UnsignedInt
  last_read_at         DateTime?                       @db.DateTime(0)
  chat_threads         chat_threads                    @relation(fields: [thread_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ctm_thread")
  users                users                           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ctm_user")

  @@id([thread_id, user_id])
  @@index([user_id], map: "idx_ctm_user")
}

model chat_thread_messages {
  id               Int          @id @default(autoincrement()) @db.UnsignedInt
  thread_id        Int          @db.UnsignedInt
  sender_id        Int          @db.UnsignedInt
  body             String       @db.Text
  attachments_json Json?
  created_at       DateTime     @default(now()) @db.DateTime(0)
  users            users        @relation(fields: [sender_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_chat_msg_sender")
  chat_threads     chat_threads @relation(fields: [thread_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_chat_msg_thread")

  @@index([sender_id], map: "idx_ctm_sender")
  @@index([thread_id, id], map: "idx_ctm_thread")
}

model chat_threads {
  id                   Int                      @id @default(autoincrement()) @db.UnsignedInt
  thread_type          chat_threads_thread_type @default(direct)
  title                String?                  @db.VarChar(200)
  created_by           Int?                     @db.UnsignedInt
  created_at           DateTime                 @default(now()) @db.DateTime(0)
  updated_at           DateTime                 @default(now()) @db.DateTime(0)
  chat_direct_pairs    chat_direct_pairs[]
  chat_thread_members  chat_thread_members[]
  chat_thread_messages chat_thread_messages[]
  users                users?                   @relation(fields: [created_by], references: [id], onUpdate: NoAction, map: "fk_chat_thread_creator")

  @@index([created_by], map: "idx_created_by")
  @@index([thread_type], map: "idx_thread_type")
}

model companies {
  id                   Int        @id @default(autoincrement()) @db.UnsignedInt
  account_name         String     @db.VarChar(180)
  account_relationship String?    @default("Customer") @db.VarChar(80)
  phone                String?    @db.VarChar(30)
  email                String?    @db.VarChar(180)
  industry             String?    @db.VarChar(120)
  street               String?    @db.VarChar(255)
  city                 String?    @db.VarChar(120)
  state                String?    @db.VarChar(120)
  country              String?    @db.VarChar(120)
  postal_code          String?    @db.VarChar(20)
  website              String?    @db.VarChar(255)
  notes                String?    @db.Text
  assigned_to          Int?       @db.UnsignedInt
  created_by           Int?       @db.UnsignedInt
  created_at           DateTime   @default(now()) @db.DateTime(0)
  updated_at           DateTime   @default(now()) @db.DateTime(0)
  is_starred           Boolean    @default(false)
  is_deleted           Boolean    @default(false)
  deleted_at           DateTime?  @db.DateTime(0)
  contacts             contacts[]

  @@index([assigned_to], map: "idx_companies_assigned")
  @@index([city], map: "idx_companies_city")
  @@index([created_by], map: "idx_companies_created_by")
  @@index([is_deleted], map: "idx_companies_is_deleted")
  @@index([is_starred], map: "idx_companies_is_starred")
  @@index([account_name], map: "idx_companies_name")
  @@index([account_relationship], map: "idx_companies_rel")
  @@index([state], map: "idx_companies_state")
}

model company_settings {
  id                 Int      @id @default(1) @db.UnsignedInt
  company_name       String?  @db.VarChar(200)
  website            String?  @db.VarChar(300)
  phone              String?  @db.VarChar(20)
  email              String?  @db.VarChar(150)
  address            String?  @db.Text
  city               String?  @db.VarChar(100)
  state              String?  @db.VarChar(100)
  country            String?  @default("India") @db.VarChar(100)
  gst_number         String?  @db.VarChar(50)
  pan_number         String?  @db.VarChar(50)
  invoice_bank_name  String?  @db.VarChar(200)
  invoice_account_no String?  @db.VarChar(64)
  invoice_ifsc       String?  @db.VarChar(20)
  invoice_currency   String   @default("INR") @db.VarChar(10)
  invoice_gst_mode   String   @default("none") @db.VarChar(20)
  updated_at         DateTime @default(now()) @db.DateTime(0)
}

model contacts {
  id                                Int        @id @default(autoincrement()) @db.UnsignedInt
  company_name                      String     @db.VarChar(180)
  contact_name                      String     @db.VarChar(150)
  designation                       String?    @db.VarChar(120)
  account_relationship              String?    @db.VarChar(80)
  department                        String?    @db.VarChar(120)
  email                             String?    @db.VarChar(180)
  phone                             String?    @db.VarChar(30)
  street                            String?    @db.VarChar(255)
  city                              String?    @db.VarChar(120)
  state                             String?    @db.VarChar(120)
  country                           String?    @db.VarChar(120)
  postal_code                       String?    @db.VarChar(20)
  website                           String?    @db.VarChar(255)
  notes                             String?    @db.Text
  assigned_to                       Int?       @db.UnsignedInt
  created_by                        Int?       @db.UnsignedInt
  created_at                        DateTime   @default(now()) @db.DateTime(0)
  updated_at                        DateTime   @default(now()) @db.DateTime(0)
  company_id                        Int?       @db.UnsignedInt
  users_contacts_assigned_toTousers users?     @relation("contacts_assigned_toTousers", fields: [assigned_to], references: [id], onUpdate: NoAction, map: "fk_contacts_assigned")
  companies                         companies? @relation(fields: [company_id], references: [id], onUpdate: NoAction, map: "fk_contacts_company")
  users_contacts_created_byTousers  users?     @relation("contacts_created_byTousers", fields: [created_by], references: [id], onUpdate: NoAction, map: "fk_contacts_creator")

  @@index([company_id], map: "fk_contacts_company")
  @@index([assigned_to], map: "idx_contacts_assigned")
  @@index([company_name], map: "idx_contacts_company")
  @@index([created_by], map: "idx_contacts_created_by")
  @@index([department], map: "idx_contacts_department")
  @@index([designation], map: "idx_contacts_designation")
  @@index([account_relationship], map: "idx_contacts_relationship")
}

model coupons {
  id               Int       @id @default(autoincrement()) @db.UnsignedInt
  code             String    @unique(map: "uk_coupons_code") @db.VarChar(40)
  discount_percent Int       @db.UnsignedTinyInt
  description      String?   @db.VarChar(255)
  max_redemptions  Int?      @db.UnsignedInt
  redemptions_used Int       @default(0) @db.UnsignedInt
  valid_from       DateTime? @db.DateTime(0)
  valid_until      DateTime? @db.DateTime(0)
  is_active        Boolean   @default(true)
  created_at       DateTime  @default(now()) @db.DateTime(0)
  updated_at       DateTime  @default(now()) @db.DateTime(0)

  @@index([is_active], map: "idx_coupons_active")
}

model crm_calendar_events {
  id          Int       @id @default(autoincrement()) @db.UnsignedInt
  user_id     Int       @db.UnsignedInt
  title       String    @db.VarChar(220)
  description String?   @db.Text
  start_at    DateTime  @db.DateTime(0)
  end_at      DateTime? @db.DateTime(0)
  all_day     Boolean   @default(false)
  category    String    @default("event") @db.VarChar(32)
  created_at  DateTime  @default(now()) @db.DateTime(0)
  updated_at  DateTime  @default(now()) @db.DateTime(0)
  users       users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cal_event_user")

  @@index([user_id, start_at], map: "idx_cal_user_range")
}

model crm_todo_assignees {
  todo_id   Int       @db.UnsignedInt
  user_id   Int       @db.UnsignedInt
  crm_todos crm_todos @relation(fields: [todo_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_todo_asg_todo")
  users     users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_todo_asg_user")

  @@id([todo_id, user_id])
  @@index([user_id], map: "fk_todo_asg_user")
}

model crm_todos {
  id                 Int                  @id @default(autoincrement()) @db.UnsignedInt
  body               String               @db.Text
  frequency          crm_todos_frequency  @default(once)
  todo_date          DateTime             @db.Date
  priority           crm_todos_priority   @default(medium)
  carry_forward      Boolean              @default(false)
  status             crm_todos_status     @default(pending)
  completed_at       DateTime?            @db.DateTime(0)
  attachment_json    Json?
  created_by         Int                  @db.UnsignedInt
  created_at         DateTime             @default(now()) @db.DateTime(0)
  updated_at         DateTime             @default(now()) @db.DateTime(0)
  client_id          String?              @db.VarChar(20)
  todo_category      String?              @db.VarChar(50)
  is_deleted         Boolean              @default(false)
  deleted_at         DateTime?            @db.DateTime(0)
  tenant_id          Int?                 @db.UnsignedInt
  crm_todo_assignees crm_todo_assignees[]
  users              users                @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_crm_todo_creator")

  @@index([created_by], map: "idx_created_by")
  @@index([is_deleted], map: "idx_crm_todos_is_deleted")
  @@index([frequency], map: "idx_frequency")
  @@index([status], map: "idx_status")
  @@index([todo_date], map: "idx_todo_date")
}

model customers {
  id         Int       @id @default(autoincrement()) @db.UnsignedInt
  name       String    @db.VarChar(200)
  email      String?   @db.VarChar(200)
  phone      String?   @db.VarChar(50)
  company    String?   @db.VarChar(200)
  city       String?   @db.VarChar(100)
  country    String?   @default("India") @db.VarChar(100)
  lead_id    Int?      @unique(map: "lead_id") @db.UnsignedInt
  created_at DateTime  @default(now()) @db.DateTime(0)
  updated_at DateTime  @default(now()) @db.DateTime(0)
  is_deleted Boolean   @default(false)
  deleted_at DateTime? @db.DateTime(0)

  @@index([is_deleted], map: "idx_customers_is_deleted")
  @@index([lead_id], map: "idx_lead_id")
}

model fitness_body_stats {
  id             Int       @id @default(autoincrement()) @db.UnsignedInt
  client_id      String    @db.VarChar(20)
  recorded_date  DateTime  @db.Date
  weight_kg      Decimal?  @db.Decimal(5, 2)
  body_fat_pct   Decimal?  @db.Decimal(5, 2)
  muscle_mass_kg Decimal?  @db.Decimal(5, 2)
  waist_cm       Decimal?  @db.Decimal(5, 2)
  notes          String?   @db.Text
  created_at     DateTime? @default(now()) @db.Timestamp(0)

  @@index([client_id], map: "idx_fitness_body_stats_client")
  @@index([recorded_date], map: "idx_fitness_body_stats_date")
}

model fitness_client_tasks {
  id               Int                            @id @default(autoincrement()) @db.UnsignedInt
  client_id        String                         @db.VarChar(20)
  task_description String                         @db.Text
  due_date         DateTime?                      @db.Date
  priority         fitness_client_tasks_priority? @default(Medium)
  status           fitness_client_tasks_status?   @default(Open)
  period           String?                        @db.VarChar(50)
  completed_on     DateTime?                      @db.Date
  notes            String?                        @db.Text
  created_at       DateTime?                      @default(now()) @db.Timestamp(0)
  updated_at       DateTime?                      @default(now()) @db.Timestamp(0)

  @@index([client_id], map: "idx_fitness_client_tasks_client")
  @@index([due_date], map: "idx_fitness_client_tasks_due")
  @@index([status], map: "idx_fitness_client_tasks_status")
}

model fitness_clients {
  id                      Int                        @id @default(autoincrement()) @db.UnsignedInt
  client_id               String                     @unique(map: "client_id") @db.VarChar(20)
  full_name               String                     @db.VarChar(255)
  status                  fitness_clients_status?    @default(Active)
  progress                fitness_clients_progress?  @default(Neutral)
  phone                   String?                    @db.VarChar(20)
  email                   String?                    @db.VarChar(255)
  age                     Int?
  city                    String?                    @db.VarChar(100)
  address                 String?                    @db.Text
  occupation              String?                    @db.VarChar(100)
  emergency_contact       String?                    @db.VarChar(255)
  referred_by_client_id   String?                    @db.VarChar(20)
  referred_by_name        String?                    @db.VarChar(255)
  source                  fitness_clients_source?    @default(Walk_in)
  tier                    Int?                       @default(3) @db.TinyInt
  health_goal             String?                    @db.VarChar(255)
  plan_type               fitness_clients_plan_type?
  plan_start_date         DateTime?                  @db.Date
  plan_expiry_date        DateTime?                  @db.Date
  follow_up_freq_days     Int?                       @default(14)
  last_consultation_date  DateTime?                  @db.Date
  next_due_date           DateTime?                  @db.Date
  medical_conditions      String?                    @db.Text
  allergies               String?                    @db.Text
  activity_level          String?                    @db.VarChar(100)
  current_medications     String?                    @db.Text
  height_cm               Decimal?                   @db.Decimal(5, 2)
  start_weight_kg         Decimal?                   @db.Decimal(5, 2)
  current_weight_kg       Decimal?                   @db.Decimal(5, 2)
  target_weight_kg        Decimal?                   @db.Decimal(5, 2)
  bmi                     Decimal?                   @db.Decimal(5, 2)
  coach_notes             String?                    @db.Text
  created_at              DateTime?                  @default(now()) @db.Timestamp(0)
  updated_at              DateTime?                  @default(now()) @db.Timestamp(0)
  fitness_external_buyers fitness_external_buyers[]

  @@index([client_id], map: "idx_fitness_clients_client_id")
  @@index([next_due_date], map: "idx_fitness_clients_next_due")
  @@index([status], map: "idx_fitness_clients_status")
}

model fitness_collection_payments {
  id                  Int                                   @id @default(autoincrement()) @db.UnsignedInt
  collection_id       Int                                   @db.UnsignedInt
  amount_inr          Decimal                               @db.Decimal(10, 2)
  pay_mode            fitness_collection_payments_pay_mode? @default(GPay)
  paid_at             DateTime                              @db.Date
  notes               String?                               @db.Text
  created_by          Int?                                  @db.UnsignedInt
  created_at          DateTime?                             @default(now()) @db.Timestamp(0)
  fitness_collections fitness_collections                   @relation(fields: [collection_id], references: [id], onDelete: Cascade, map: "fk_fcp_collection")

  @@index([collection_id], map: "idx_fcp_collection")
}

model fitness_collections {
  id                          Int                                 @id @default(autoincrement()) @db.UnsignedInt
  client_id                   String?                             @db.VarChar(20)
  external_buyer_id           Int?                                @db.UnsignedInt
  collection_type             fitness_collections_collection_type @default(other)
  title                       String                              @db.VarChar(255)
  total_inr                   Decimal                             @default(0.00) @db.Decimal(10, 2)
  received_inr                Decimal                             @default(0.00) @db.Decimal(10, 2)
  pending_inr                 Decimal                             @default(0.00) @db.Decimal(10, 2)
  next_followup_date          DateTime?                           @db.Date
  assigned_to                 Int?                                @db.UnsignedInt
  status                      fitness_collections_status          @default(open)
  linked_transaction_id       Int?                                @db.UnsignedInt
  linked_supplement_id        Int?                                @db.UnsignedInt
  notes                       String?                             @db.Text
  created_by                  Int?                                @db.UnsignedInt
  created_at                  DateTime?                           @default(now()) @db.Timestamp(0)
  updated_at                  DateTime?                           @default(now()) @db.Timestamp(0)
  fitness_collection_payments fitness_collection_payments[]
  fitness_external_buyers     fitness_external_buyers?            @relation(fields: [external_buyer_id], references: [id], onDelete: Restrict, map: "fk_fc_coll_external")

  @@index([assigned_to], map: "idx_fc_assigned")
  @@index([client_id], map: "idx_fc_client")
  @@index([external_buyer_id], map: "idx_fc_external")
  @@index([next_followup_date], map: "idx_fc_followup")
  @@index([linked_transaction_id], map: "idx_fc_linked_tx")
  @@index([status], map: "idx_fc_status")
}

model fitness_consultations {
  id               Int                                @id @default(autoincrement()) @db.UnsignedInt
  client_id        String                             @db.VarChar(20)
  consult_date     DateTime                           @db.Date
  consult_type     fitness_consultations_consult_type
  weight_kg        Decimal?                           @db.Decimal(5, 2)
  key_observations String?                            @db.Text
  diet_changes     String?                            @db.Text
  next_steps       String?                            @db.Text
  next_appointment String?                            @db.VarChar(100)
  created_at       DateTime?                          @default(now()) @db.Timestamp(0)

  @@index([client_id], map: "idx_fitness_consultations_client")
  @@index([consult_date], map: "idx_fitness_consultations_date")
}

model fitness_external_buyers {
  id                    Int                    @id @default(autoincrement()) @db.UnsignedInt
  full_name             String                 @db.VarChar(255)
  phone                 String?                @unique(map: "uk_fitness_external_buyers_phone") @db.VarChar(20)
  referred_by_client_id String?                @db.VarChar(20)
  notes                 String?                @db.Text
  created_at            DateTime?              @default(now()) @db.Timestamp(0)
  updated_at            DateTime?              @default(now()) @db.Timestamp(0)
  fitness_collections   fitness_collections[]
  fitness_clients       fitness_clients?       @relation(fields: [referred_by_client_id], references: [client_id], map: "fk_feb_referred_client")
  fitness_transactions  fitness_transactions[]

  @@index([referred_by_client_id], map: "idx_feb_referred")
}

model fitness_meal_plans {
  id           Int       @id @default(autoincrement()) @db.UnsignedInt
  client_id    String    @db.VarChar(20)
  plan_name    String    @db.VarChar(255)
  start_date   DateTime? @db.Date
  end_date     DateTime? @db.Date
  calories     Int?
  protein_g    Int?
  carbs_g      Int?
  fats_g       Int?
  plan_pdf_url String?   @db.Text
  notes        String?   @db.Text
  is_active    Boolean?  @default(true)
  created_at   DateTime? @default(now()) @db.Timestamp(0)
  updated_at   DateTime? @default(now()) @db.Timestamp(0)

  @@index([client_id], map: "idx_fitness_meal_plans_client")
}

model fitness_referrals {
  id                 Int       @id @default(autoincrement()) @db.UnsignedInt
  referrer_client_id String    @db.VarChar(20)
  referred_client_id String    @db.VarChar(20)
  referral_date      DateTime? @db.Date
  notes              String?   @db.Text
  created_at         DateTime? @default(now()) @db.Timestamp(0)

  @@index([referred_client_id], map: "idx_fitness_referrals_referred")
  @@index([referrer_client_id], map: "idx_fitness_referrals_referrer")
}

model fitness_settings {
  id            Int       @id @default(autoincrement()) @db.UnsignedInt
  setting_key   String    @unique(map: "setting_key") @db.VarChar(100)
  setting_value Json
  created_at    DateTime? @default(now()) @db.Timestamp(0)
  updated_at    DateTime? @default(now()) @db.Timestamp(0)
}

model fitness_supplements {
  id              Int       @id @default(autoincrement()) @db.UnsignedInt
  client_id       String    @db.VarChar(20)
  product_name    String    @db.VarChar(255)
  prescribed_date DateTime? @db.Date
  quantity        Int?
  mrp_inr         Decimal?  @db.Decimal(10, 2)
  rate_inr        Decimal?  @db.Decimal(10, 2)
  notes           String?   @db.Text
  created_at      DateTime? @default(now()) @db.Timestamp(0)

  @@index([client_id], map: "idx_fitness_supplements_client")
}

model fitness_transactions {
  id                      Int                            @id @default(autoincrement()) @db.UnsignedInt
  client_id               String?                        @db.VarChar(20)
  external_buyer_id       Int?                           @db.UnsignedInt
  transaction_date        DateTime                       @db.Date
  product_plan            String                         @db.VarChar(255)
  type                    fitness_transactions_type
  mrp_inr                 Decimal?                       @db.Decimal(10, 2)
  rate_inr                Decimal?                       @db.Decimal(10, 2)
  received_inr            Decimal?                       @default(0.00) @db.Decimal(10, 2)
  pending_inr             Decimal?                       @default(0.00) @db.Decimal(10, 2)
  payment_due_date        DateTime?                      @db.Date
  cost_inr                Decimal?                       @default(0.00) @db.Decimal(10, 2)
  profit_inr              Decimal?                       @db.Decimal(10, 2)
  pay_mode                fitness_transactions_pay_mode? @default(GPay)
  notes                   String?                        @db.Text
  created_at              DateTime?                      @default(now()) @db.Timestamp(0)
  fitness_external_buyers fitness_external_buyers?       @relation(fields: [external_buyer_id], references: [id], onDelete: Restrict, map: "fk_fitness_transactions_external")

  @@index([client_id], map: "idx_fitness_transactions_client")
  @@index([transaction_date], map: "idx_fitness_transactions_date")
  @@index([external_buyer_id], map: "idx_fitness_transactions_external")
  @@index([payment_due_date], map: "idx_fitness_transactions_payment_due")
  @@index([type], map: "idx_fitness_transactions_type")
}

model integration_webhooks {
  id            Int                         @id @default(autoincrement()) @db.UnsignedInt
  source_key    String                      @db.VarChar(100)
  status        integration_webhooks_status @default(received)
  payload_json  Json?
  headers_json  Json?
  lead_id       Int?                        @db.UnsignedInt
  error_message String?                     @db.Text
  created_at    DateTime                    @default(now()) @db.DateTime(0)

  @@index([lead_id], map: "idx_lead_id")
  @@index([source_key], map: "idx_source_key")
  @@index([status], map: "idx_status")
}

model integrations {
  id         Int      @id @default(autoincrement()) @db.UnsignedInt
  key        String   @unique(map: "key") @db.VarChar(100)
  name       String   @db.VarChar(200)
  is_active  Boolean  @default(false)
  created_at DateTime @default(now()) @db.DateTime(0)
}

model invoices {
  id                Int             @id @default(autoincrement()) @db.UnsignedInt
  invoice_number    String          @unique(map: "uk_invoice_number") @db.VarChar(50)
  type              invoices_type   @default(sales)
  customer_name     String?         @db.VarChar(150)
  customer_email    String?         @db.VarChar(150)
  customer_phone    String?         @db.VarChar(32)
  vendor_name       String?         @db.VarChar(150)
  invoice_date      DateTime        @db.Date
  due_date          DateTime?       @db.Date
