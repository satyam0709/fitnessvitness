{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"const fs=require('fs');['.next','node_modules/.cache'].forEach(p=>{if(fs.existsSync(p))fs.rmSync(p,{recursive:true,force:true});});\"",
    "dev": "next dev",
    "dev:fresh": "npm run clean && next dev",
    "dev:turbo": "npm run clean && next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.4.0",
    "next": "^15.2.8",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "eslint": "^9",
    "eslint-config-next": "^15.2.8",
    "typescript": "^6.0.2"
  }
}
